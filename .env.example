# ============================================
# KisanMind — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_REGION=asia-south1
EE_PROJECT=your-ee-project

# --- Google Maps + Weather API ---
GOOGLE_MAPS_API_KEY=your-key

# --- Gemini AI ---
GEMINI_API_KEY=your-key

# --- External APIs ---
AGMARKNET_API_KEY=your-key

# --- Storage ---
GCS_CACHE_BUCKET=kisanmind-cache

# --- Base URL ---
BASE_URL=https://kisanmind.dmj.one

# Optional: Twilio (for voice calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: Earth Engine service account
EE_SERVICE_KEY_JSON=
EE_SERVICE_KEY_PATH=
