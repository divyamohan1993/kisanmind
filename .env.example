# ============================================
# KisanMind — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=lmsforshantithakur
GOOGLE_CLOUD_REGION=asia-south1
EE_PROJECT=dmjone

# --- Google Maps + Weather API ---
# Cloud Console → APIs & Services → Credentials
# Enable: Geocoding API, Distance Matrix API, Weather API
GOOGLE_MAPS_API_KEY=

# --- Gemini AI ---
# Cloud Console → APIs & Services → Credentials → Create API Key
# Restrict to: Generative Language API
GEMINI_API_KEY=

# --- External APIs ---
# AgMarkNet: https://data.gov.in → Register → Request API key for commodity prices
AGMARKNET_API_KEY=
